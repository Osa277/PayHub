# =========================
# PayHub Environment Variables
# =========================
# Copy this file to .env and fill in the values.

# ---- Database (PostgreSQL) ----
# Free options: neon.tech, supabase.com, railway.app
DATABASE_URL="postgresql://user:password@host:5432/payhub?sslmode=require"

# ---- NextAuth ----
# NEXTAUTH_URL must match your deployed domain (no trailing slash)
NEXTAUTH_URL="https://yourdomain.com"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# ---- Crypto Payments (NOWPayments) ----
# Sign up at https://nowpayments.io — get API key from dashboard
# Leave commented to run in demo mode (no real payments)
# NOWPAYMENTS_API_KEY=""
# NOWPAYMENTS_IPN_SECRET=""
# NOWPAYMENTS_SANDBOX="true"

# ---- Email (Resend) ----
# Sign up at https://resend.com — get API key from dashboard
# Leave commented to skip sending emails (logged to console instead)
# RESEND_API_KEY=""
# EMAIL_FROM="PayHub <noreply@yourdomain.com>"

# ---- Optional ----
# NEXT_PUBLIC_API_URL="https://yourdomain.com"
