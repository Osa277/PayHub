# Database (PostgreSQL on Neon)
# Get connection string from https://console.neon.tech
DATABASE_URL="postgresql://user:password@host/database"

# NextAuth Configuration
# Generate secret with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your_nextauth_secret_here"

# Google OAuth - Get credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# Paystack - Get keys at https://dashboard.paystack.com/#/settings/developers
# Use sk_test_ keys for testing, sk_live_ for production
PAYSTACK_SECRET_KEY="sk_live_your_secret_key"
PAYSTACK_PUBLIC_KEY="pk_live_your_public_key"

# NOWPayments - Get API key from https://nowpayments.io
NOWPAYMENTS_API_KEY="your_nowpayments_api_key"
NOWPAYMENTS_IPN_SECRET="your_nowpayments_ipn_secret"
# NOWPAYMENTS_SANDBOX="false"  # Set to "true" for sandbox testing

# Email (Resend) - Get key at https://resend.com
RESEND_API_KEY="re_your_resend_api_key"
# EMAIL_FROM="PayHub <noreply@yourdomain.com>"

# SMS (Twilio) - Optional, get credentials at https://console.twilio.com
# TWILIO_ACCOUNT_SID="your_twilio_account_sid"
# TWILIO_AUTH_TOKEN="your_twilio_auth_token"
# TWILIO_PHONE_NUMBER="+1234567890"
