generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Models ───

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  phone          String?
  country        String?
  avatar         String?
  bio            String?
  transactionPin String?   // Hashed 4-digit PIN for payment confirmation
  isVerified     Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  wallet              Wallet?
  transactions        Transaction[]
  invoices            Invoice[]
  paymentMethods      PaymentMethod[]
  paymentSessions     PaymentSession[]
  bankAccounts        BankAccount[]
  // Crypto fields removed for Paystack-only
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Business Models ───

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Decimal  @default(0) @db.Decimal(18, 8)
  currency  String   @default("NGN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id              String   @id @default(cuid())
  userId          String
  type            String   // payment, transfer, deposit, withdrawal
  amount          Decimal  @db.Decimal(18, 8)
  currency        String   @default("NGN")
  status          String   @default("pending") // pending, completed, failed
  description     String
  recipientId     String?
  recipientName   String?
  recipientEmail  String?
  fee             Decimal  @default(0) @db.Decimal(18, 8)
  paymentMethodId String?
  bankAccountId   String?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  bankAccount   BankAccount?   @relation(fields: [bankAccountId], references: [id])
  invoice       Invoice?

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, status])
  @@index([status, createdAt(sort: Desc)])
}

model PaymentMethod {
  id        String   @id @default(cuid())
  userId    String
  type      String   // paystack
  stripeId  String?
  paypalId  String?
  last4     String?
  brand     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
}

model Invoice {
  id             String   @id @default(cuid())
  userId         String
  transactionId  String   @unique
  amount         Decimal  @db.Decimal(18, 8)
  currency       String   @default("NGN")
  status         String   @default("draft") // draft, sent, paid, overdue
  recipientEmail String?
  recipientName  String?
  items          Json
  dueDate        DateTime
  isRecurring       Boolean  @default(false)
  recurrencePattern String?  // daily, weekly, monthly, yearly
  recurrenceInterval Int     @default(1) // every N periods
  nextDueDate       DateTime?
  lastSentAt        DateTime?
  parentInvoiceId   String?  // links child invoices to their recurring parent
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction Transaction @relation(fields: [transactionId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, status])
  @@index([isRecurring, nextDueDate, status])
}

model PaymentSession {
  id              String   @id @default(cuid())
  userId          String
  amount          Decimal  @db.Decimal(18, 8)
  currency        String   @default("NGN")
  paymentProvider String   // paystack
  status          String   @default("pending") // pending, completed, failed, cancelled
  stripeSessionId String?  @unique
  redirectUrl     String?
  expiresAt       DateTime
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model BankAccount {
  id            String   @id @default(cuid())
  userId        String
  accountNumber String
  bankCode      String
  bankName      String
  accountName   String
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([userId, accountNumber, bankCode])
  @@index([userId])
}

